# Jina AI Configuration
JINA_API_KEY=your-jina-api-key
JINA_API_BASE_URL=https://api.jina.ai/v1
JINA_API_TIMEOUT=60

# Embedding Configuration
EMBEDDING_PROVIDER=jina
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=100
JINA_EMBEDDING_MODEL=jina-embeddings-v3
OLLAMA_EMBEDDING_MODEL=harrier-oss-v1-0.6b
OLLAMA_EMBEDDING_TIMEOUT=120

# Reranker Configuration
RERANKER_PROVIDER=jina
RERANKER_ENABLED=true
RERANKER_TOP_K=50
RERANKER_RETURN_TOP_K=10
JINA_RERANKER_MODEL=jina-reranker-v2-base-multilingual
OLLAMA_RERANKER_MODEL=Qwen3-Reranker-0.6B
OLLAMA_RERANKER_TIMEOUT=120

# Text Processing Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
CHUNK_OVERLAP_SENTENCES=2
MIN_CHUNK_SIZE=100
SEMANTIC_CHUNK_THRESHOLD=0.45

# Hybrid Search Configuration
SEARCH_VECTOR_WEIGHT=0.7
SEARCH_TRIGRAM_WEIGHT=0.3
TRIGRAM_THRESHOLD=0.1
RRF_K=60

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here

# OLLAMA
OLLAMA_BASE_URL=http://ollama:11434

# LLM Configuration
# Both local and cloud profiles are defined. Switch between them at runtime

# Answer Generation (Local / Ollama)
LLM_LOCAL_PROVIDER=ollama
LLM_LOCAL_MODEL=gemma3:12b
LLM_LOCAL_TIMEOUT=120
LLM_LOCAL_API_KEY=

# Answer Generation (Cloud / OpenAI)
LLM_CLOUD_PROVIDER=openai
LLM_CLOUD_MODEL=gpt-4o-mini
LLM_CLOUD_TIMEOUT=30
LLM_CLOUD_API_KEY=${OPENAI_API_KEY}

# Shared LLM Parameters
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=1.0

# Intent Classification (Local / Ollama)
INTENT_LOCAL_PROVIDER=ollama
INTENT_LOCAL_MODEL=phi4-mini:3.8b
INTENT_LOCAL_TIMEOUT=30
INTENT_LOCAL_API_KEY=

# Intent Classification (Cloud / OpenAI)
INTENT_CLOUD_PROVIDER=openai
INTENT_CLOUD_MODEL=gpt-4o-mini
INTENT_CLOUD_TIMEOUT=10
INTENT_CLOUD_API_KEY=${OPENAI_API_KEY}

# Shared Intent Parameters
INTENT_LLM_MAX_TOKENS=500
INTENT_LLM_TEMPERATURE=1.0

# Document Processing
DOCUMENTS_SOURCE_FOLDER=storage/app/documents

# Retrieval Settings
RETRIEVAL_DEFAULT_LIMIT=10
SIMILARITY_THRESHOLD=0.7

# PostgreSQL Configuration
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=postgresql_vector_db
DB_USERNAME=postgresql
DB_PASSWORD=postgresql_password

# Application Settings
APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:example-app-key-here
APP_DEBUG=true
APP_URL=http://localhost
CORS_ALLOWED_ORIGINS=http://10.1.7.56:5173,http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"